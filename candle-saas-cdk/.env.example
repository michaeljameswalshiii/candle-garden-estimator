# Example environment configuration
# Copy to .env and update with your values

# AWS Configuration
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
AWS_PROFILE=default

# Database Configuration
DB_HOST=candlesaasdb.xxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=candledb
DB_USER=candleadmin
DB_PASSWORD=your-secure-password

# S3 Configuration
S3_BUCKET=candle-images-123456789012-us-east-1
S3_BACKUP_BUCKET=candle-backup-123456789012-us-east-1

# Lambda Configuration
LAMBDA_TIMEOUT=60
LAMBDA_MEMORY_SIZE=512
LAMBDA_EPHEMERAL_STORAGE=512

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION=us-east-1

# API Configuration
API_STAGE=dev
API_CORS_ORIGIN=*

# Feature Flags
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_IMAGE_PROCESSING=true
ENABLE_ORDER_EMAIL_NOTIFICATIONS=false

# Logging
LOG_LEVEL=INFO
CLOUDWATCH_LOG_RETENTION_DAYS=14

# Development
DEBUG=false
